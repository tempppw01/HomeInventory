{
  "name": "home-inventory",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:init:sqlite": "tsx scripts/init-sqlite.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "npm run db:generate && npm run db:init:sqlite && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "fast-check": "^4.9.0",
    "lucide-react": "^0.468.0",
    "motion": "^12.0.0",
    "next": "16.2.10",
    "prisma": "^6.19.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tsx": "^4.19.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
