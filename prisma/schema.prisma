generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ItemType {
  DURABLE
  CONSUMABLE
}

enum ShoppingStatus {
  PENDING
  PURCHASED
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String   @default("Package")
  color     String   @default("#7c3aed")
  items     Item[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id               String        @id @default(cuid())
  itemCode         String?       @unique
  name             String
  category         String
  type             ItemType      @default(DURABLE)
  quantity         Float         @default(1)
  minQuantity      Float         @default(0)
  remainingPercent Float         @default(100)
  unit             String        @default("件")
  price            Float?
  purchaseDate     DateTime?
  expiryDate       DateTime?
  imageUrl         String?
  notes            String?
  locationId       String?
  location         Location?     @relation(fields: [locationId], references: [id], onDelete: SetNull)
  priceRecords     PriceRecord[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([type])
  @@index([category])
  @@index([locationId])
  @@index([expiryDate])
}

model PriceRecord {
  id          String   @id @default(cuid())
  itemId      String?
  item        Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemName    String
  category    String
  unitPrice   Float
  quantity    Float    @default(1)
  totalPrice  Float
  purchasedAt DateTime @default(now())
  store       String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([itemId])
  @@index([purchasedAt])
  @@index([category])
}

model FridgeSetting {
  id        String   @id @default("default")
  enabled   Boolean  @default(true)
  targetMin Float    @default(2)
  targetMax Float    @default(8)
  updatedAt DateTime @updatedAt
}

model FridgeReading {
  id          String   @id @default(cuid())
  temperature Float
  note        String?
  recordedAt  DateTime @default(now())

  @@index([recordedAt])
}

model OssSetting {
  id              String   @id @default("default")
  region          String
  endpoint        String?
  bucket          String
  accessKeyId     String
  accessKeySecret String
  publicBaseUrl   String?
  updatedAt       DateTime @updatedAt
}

model AiSetting {
  id        String   @id @default("default")
  baseUrl   String
  apiKey    String
  model     String
  updatedAt DateTime @updatedAt
}

model ShoppingItem {
  id        String         @id @default(cuid())
  name      String
  quantity  Float          @default(1)
  unit      String         @default("件")
  category  String?
  priority  Int            @default(1)
  status    ShoppingStatus @default(PENDING)
  source    String         @default("manual")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status])
}
