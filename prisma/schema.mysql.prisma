generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ItemType {
  DURABLE
  CONSUMABLE
}

enum ShoppingStatus {
  PENDING
  PURCHASED
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String   @default("Package")
  color     String   @default("#7c3aed")
  items     Item[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id           String    @id @default(cuid())
  itemCode     String?   @unique
  name         String
  category     String
  type         ItemType  @default(DURABLE)
  quantity     Float     @default(1)
  minQuantity  Float     @default(0)
  unit         String    @default("件")
  price        Float?
  purchaseDate DateTime?
  expiryDate   DateTime?
  imageUrl     String?   @db.Text
  notes        String?   @db.Text
  locationId   String?
  location     Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  priceRecords PriceRecord[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type])
  @@index([category])
  @@index([locationId])
  @@index([expiryDate])
}

model PriceRecord {
  id          String   @id @default(cuid())
  itemId      String?
  item        Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
  itemName    String
  category    String
  unitPrice   Float
  quantity    Float    @default(1)
  totalPrice  Float
  purchasedAt DateTime @default(now())
  store       String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  @@index([itemId])
  @@index([purchasedAt])
  @@index([category])
}

model FridgeSetting {
  id        String   @id @default("default")
  enabled   Boolean  @default(true)
  targetMin Float    @default(2)
  targetMax Float    @default(8)
  updatedAt DateTime @updatedAt
}

model FridgeReading {
  id          String   @id @default(cuid())
  temperature Float
  note        String?  @db.Text
  recordedAt  DateTime @default(now())

  @@index([recordedAt])
}

model OssSetting {
  id              String   @id @default("default")
  region          String
  endpoint        String?
  bucket          String
  accessKeyId     String
  accessKeySecret String
  publicBaseUrl   String?  @db.Text
  updatedAt       DateTime @updatedAt
}

model AiSetting {
  id        String   @id @default("default")
  baseUrl   String   @db.Text
  apiKey    String   @db.Text
  model     String
  updatedAt DateTime @updatedAt
}

model ShoppingItem {
  id        String         @id @default(cuid())
  name      String
  quantity  Float          @default(1)
  unit      String         @default("件")
  category  String?
  priority  Int            @default(1)
  status    ShoppingStatus @default(PENDING)
  source    String         @default("manual")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([status])
}
